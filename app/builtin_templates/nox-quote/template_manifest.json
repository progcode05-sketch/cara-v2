      "render_variant": "content"
    },
    "problem": {
      "role": "problem",
      "description": "Pain point slide.",
      "slots": [
        "stamp_brand",
        "stamp_site",
        "author_picture",
        "page_number",
        "context_label",
        "quote",
        "author_name",
        "attribution_topic"
      ],
      "render_variant": "content"
    },
    "framework": {
      "role": "framework",
      "description": "Framework or principle slide.",
      "slots": [
        "stamp_brand",
        "stamp_site",
        "author_picture",
        "page_number",
        "context_label",
        "quote",
        "author_name",
        "attribution_topic"
