      "required": false,
      "max_chars": 32,
      "mode": "deterministic",
      "prompt_role": null
    },
    "author_picture": {
      "name": "author_picture",
      "slot_type": "text",
      "required": false,
      "max_chars": 600,
      "mode": "deterministic",
      "prompt_role": null
    },
    "page_number": {
      "name": "page_number",
      "slot_type": "text",
      "required": true,
      "max_chars": 12,
      "mode": "deterministic",
      "prompt_role": null
    },
    "context_label": {
      "name": "context_label",
      "slot_type": "text",
      "required": false,
      "max_chars": 60,
      "mode": "deterministic",
      "prompt_role": null
