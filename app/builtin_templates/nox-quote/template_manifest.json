    "author_name": {
      "name": "author_name",
      "slot_type": "text",
      "required": false,
      "max_chars": 40,
      "mode": "deterministic",
      "prompt_role": null
    },
    "attribution_topic": {
      "name": "attribution_topic",
      "slot_type": "text",
      "required": false,
      "max_chars": 60,
      "mode": "deterministic",
      "prompt_role": null
    }
  },
  "slide_roles": {
    "cover": {
      "role": "cover",
      "description": "Opening hook slide for this template.",
      "slots": [
        "stamp_brand",
        "stamp_site",
        "author_picture",
        "page_number",
        "context_label",
        "quote",
        "author_name",
        "attribution_topic"
